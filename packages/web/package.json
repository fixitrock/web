{
    "name": "@fixitrock/web",
    "version": "3.0.0",
    "private": true,
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./ui": {
            "types": "./src/ui/index.ts",
            "import": "./src/ui/index.ts",
            "default": "./src/ui/index.ts"
        },
        "./hero": {
            "types": "./src/hero/index.ts",
            "import": "./src/hero/index.ts",
            "default": "./src/hero/index.ts"
        },
        "./hero/style.css": "./src/hero/style.css",
        "./hooks": {
            "types": "./src/hooks/index.ts",
            "import": "./src/hooks/index.ts",
            "default": "./src/hooks/index.ts"
        },
        "./utils": {
            "types": "./src/utils/index.ts",
            "import": "./src/utils/index.ts",
            "default": "./src/utils/index.ts"
        },
        "./types": {
            "types": "./src/types/index.ts",
            "import": "./src/types/index.ts",
            "default": "./src/types/index.ts"
        },
        "./config": {
            "types": "./src/config/index.ts",
            "import": "./src/config/index.ts",
            "default": "./src/config/index.ts"
        }
    },
    "scripts": {
        "check-types": "tsc --noEmit"
    },
    "dependencies": {
        "@heroui/react": "^3.0.2",
        "@heroui/styles": "^3.0.2",
        "@iconify/react": "^6.0.0",
        "clsx": "^2.1.1",
        "lucide-react": "^1.7.0",
        "next-themes": "^0.4.6",
        "react-hotkeys-hook": "^5.2.4",
        "react-icons": "^5.5.0",
        "tailwind-merge": "^3.3.1"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwindcss": "^4.0.0"
    },
    "devDependencies": {
        "@repo/typescript-config": "workspace:*",
        "@types/node": "^25.0.0",
        "@types/react": "19.2.5",
        "@types/react-dom": "19.2.3",
        "typescript": "^5.9.3"
    }
}
