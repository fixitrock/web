{
    "extends": "@repo/typescript-config/react-library.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "strictNullChecks": true,
        "types": ["node", "react", "react-dom"],
        "paths": {
            "@fixitrock/web": ["./src/index.ts"],
            "@fixitrock/web/ui": ["./src/ui/index.ts"],
            "@fixitrock/web/hero": ["./src/hero/index.ts"],
            "@fixitrock/web/hooks": ["./src/hooks/index.ts"],
            "@fixitrock/web/utils": ["./src/utils/index.ts"],
            "@fixitrock/web/types": ["./src/types/index.ts"],
            "@fixitrock/web/config": ["./src/config/index.ts"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
