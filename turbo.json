{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": [
    "**/.env",
    "**/.env.local"
  ],
  "tasks": {
    "build": {
      "description": "Build application",
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "next.config.ts",
        "postcss.config.mjs",
        "tailwind.config.ts"
      ],
      "outputs": [".next/**", "dist/**"],
      "cache": true
    },
    "dev": {
      "description": "Develop application",
      "cache": false,
      "persistent": true
    },
    "start": {
      "description": "Start application",
      "cache": false,
      "dependsOn": ["build"]
    },
    "lint": {
      "description": "Lint application",
      "outputs": [".eslintcache"],
      "cache": true
    },
    "test": {
      "description": "Test application",
      "outputs": ["coverage/**"],
      "cache": true
    },
    "changelog": {
      "description": "Generate changelog",
      "cache": false
    }
  }
}
